# Pin every dependency to an exact version so the committed lockfile is the
# audited artefact (the slopcheck-substitute gate, threat T-01-SC). This is a
# real npm config key and applies to all six direct dependencies, not just one.
save-exact=true

# Dependency cooldown intent (recorded as a COMMENT, not a live key):
# `min-release-age` is NOT a real npm config key. It is a pnpm / Renovate
# setting (`minimumReleaseAge`). Adding it here as a live key would only emit
# an "Unknown user config" warning while enforcing nothing. The cooldown bites
# at the NEXT update, not the pinned initial install, so it is enforced via a
# Dependabot / Renovate `minimumReleaseAge` policy when automated updates land.

# Do NOT set `ignore-scripts`: the pa11y-ci -> pa11y -> puppeteer chain runs an
# install-time Chromium download that the accessibility floor depends on.
