{#
  Reusable components as Nunjucks macros, mirroring the DEBT blueprint and
  extended with the Food Transparency trust-rendering macro.
  Import in a template with:
    {% from "components/macros.njk" import sourcedValue, caveatBox %}

  Autoescaping is left ON throughout. No fact value or source name is ever piped
  through the safe filter: ingested and external strings are treated as
  untrusted (stored-XSS boundary, threat T-07-01).
#}

{# CaveatBox: a clearly flagged caution. #}
{% macro caveatBox(text, heading) %}
<aside class="caveat" role="note">
  <p class="caveat__heading">{{ heading or "Important" }}</p>
  <p>{{ text }}</p>
</aside>
{% endmacro %}

{# SourceNote: where a figure came from, and when. #}
{% macro sourceNote(record) %}
<p class="source-note">
  Source:
  {% if record.source_url %}<a href="{{ record.source_url }}" rel="noopener">{{ record.source_name }}</a>{% else %}{{ record.source_name }}{% endif %}.
  {% if record.date %}Figure dated {{ record.date | readableDate }}.{% endif %}
  {% if record.retrieved_date %}Retrieved {{ record.retrieved_date | readableDate }}.{% endif %}
</p>
{% endmacro %}

{#
  SourcedValue (TRUST-03 / TRUST-04): render one fact with progressive
  disclosure of its provenance.

  Contract: sourcedValue(fact, sources, label, unit, entityType)
    fact    a SourcedValue object (value, sources[], confidence, evidence,
            updated, claimType, optional checkedOn, optional note).
    sources the registry ARRAY (pass sources.sources, NOT the wrapper object;
            findBy returns undefined for a non-array, which would silently
            render an empty source list and break TRUST-03).
    label   optional inline label shown before the value.
    unit    optional unit appended to the value.
    entityType optional staleness hint threaded to the derivation (D-16).

  R-31 (load-bearing): this macro renders off the DERIVED verification state via
  the factState filter, NEVER off fact.value. Every withheld/contested record
  still carries its raw `value` in JSON by design, so this is the single point the
  whole trust model could be silently defeated - the raw value is shown ONLY when
  the fact genuinely publishes. check-render-safety.mjs fails the build on any raw
  `.value` render outside this file. Phase 3a owns the richer contested/review-due
  visuals (VRFY-11/12); this is the safe floor.

  The two trust tokens are TEXT, never colour alone (WCAG 1.4.1, SITE-04). Each
  reads "confidence {grade}" / "evidence {grade}", links to the Methodology
  anchor that defines it, and carries a visually-hidden suffix so the link text
  is distinguishable out of context rather than a bare "confidence high".

  The wrapper is a block <div>, not a <span>, because a <span> cannot validly
  contain the <details>/<ul> disclosure, and every later page inherits this macro.
#}
{% macro sourcedValue(fact, sources, label, unit, entityType) %}
{% set d = fact | factState(sources, entityType) %}
<div class="fact" data-state="{{ d.state }}">
  <p class="fact__head">
    {% if label %}<span class="fact__label">{{ label }}:</span> {% endif %}
    {%- if d.publishable %}
    <span class="fact__value">{{ d.value }}{% if unit %}{{ unit }}{% endif %}</span>
    <span class="fact__trust">
      <a class="fact__token" href="/methodology/#confidence">confidence {{ fact.confidence }}<span class="visually-hidden"> (curator certainty)</span></a>
      <a class="fact__token" href="/methodology/#evidence">evidence {{ fact.evidence }}<span class="visually-hidden"> (evidence strength)</span></a>
    </span>
    {%- if d.stale %}
    <span class="fact__review-due">Last verified {{ fact.updated | readableDate }}; review due.</span>
    {%- endif %}
    {%- elif d.contested %}
    <span class="fact__contested">Contested; sources disagree:</span>
    <ul class="fact__positions">
      {%- for p in d.positions %}
      <li class="fact__position">
        {{ p.value }}{% if unit %}{{ unit }}{% endif %} -
        {%- for id in p.sources %}
        {%- set s = sources | findBy("id", id) %}
        {% if s %}{% if s.url %}<a href="{{ s.url }}" rel="noopener">{{ s.name }}</a>{% else %}{{ s.name }}{% endif %}{% else %}Unresolved source {{ id }}{% endif %}{% if not loop.last %}; {% endif %}
        {%- endfor %}
        {%- if p.note %} ({{ p.note }}){% endif %}
      </li>
      {%- endfor %}
    </ul>
    {%- else %}
    <span class="fact__withheld">Not yet verified; withheld.</span>
    {%- endif %}
  </p>
  <details class="fact__detail">
    <summary>Source and date</summary>
    <ul class="fact__sources">
      {%- for id in fact.sources %}
      {%- set s = sources | findBy("id", id) %}
      <li>
        {% if s %}
          {% if s.url %}<a href="{{ s.url }}" rel="noopener">{{ s.name }}</a>{% else %}{{ s.name }}{% endif %}{% if s.jurisdiction %} ({{ s.jurisdiction }}){% endif %}.
        {% else %}
          Unresolved source reference: {{ id }}.
        {% endif %}
      </li>
      {%- endfor %}
    </ul>
    <p class="fact__dates">Last updated {{ fact.updated | readableDate }}.{% if fact.checkedOn %} Checked on {{ fact.checkedOn | readableDate }}.{% endif %}</p>
    {%- if fact.note and d.publishable %}
    <p class="fact__note">{{ fact.note }}</p>
    {%- endif %}
  </details>
</div>
{% endmacro %}

{#
  factCell (D-06 / F4): the inline value-or-status renderer for a table cell.

  Contract: factCell(fact, sources, unit, entityType)

  The block sourcedValue macro cannot be dropped into a <td> (it emits a
  <details>, invalid inside a table cell). This macro is the table-cell renderer:
  it gates on the SAME derived factState projection (R-31), emits ONLY spans, and
  never opens a <details>. Because it lives INSIDE this file (the sole path
  allowlisted by check-render-safety.mjs), its d.value is exempt from the raw
  ".value" default-deny; it is NOT a second render path.

  It shows d.value ONLY when the fact publishes; a withheld or contested value is
  never emitted. The reader is pointed at the full per-figure provenance block
  below the table (the id="nutrition-{key}" anchors) for sources; this cell is the
  scannable status only. British English, no em-dashes; the state copy is the
  verbatim UI-SPEC Copywriting Contract wording.
#}
{% macro factCell(fact, sources, unit, entityType) %}
{%- set d = fact | factState(sources, entityType) -%}
{%- if d.publishable -%}
<span class="fact__value">{{ d.value }}{% if unit %}{{ unit }}{% endif %}</span>{% if d.stale %} <span class="fact__review-due">review due</span>{% endif %}
{%- elif d.contested -%}
<span class="fact__contested-inline">Contested</span>
{%- else -%}
<span class="fact__withheld">Not yet verified</span>
{%- endif -%}
{% endmacro %}
